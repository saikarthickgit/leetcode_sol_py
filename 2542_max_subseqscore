class Solution:
    def maxScore(self, nums1, nums2, k):
        pairs = list(zip(nums2, nums1))
        pairs.sort(reverse=True)  # sort by nums2 descending
        print(pairs)

        heap = []
        curr_sum = 0
        result = 0
        
        for n2, n1 in pairs:
            heapq.heappush(heap, n1)
            curr_sum += n1
            
            if len(heap) > k:
                curr_sum -= heapq.heappop(heap)
            
            if len(heap) == k:
                result = max(result, curr_sum * n2)
        
        return result
        
